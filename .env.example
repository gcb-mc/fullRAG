# ATLAS-RAG Environment Variables
# Copy to .env and fill in values for local development

# Azure Identity (use DefaultAzureCredential locally, ManagedIdentity in prod)
ENVIRONMENT=development
AZURE_CLIENT_ID=

# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=

# Azure AI Services (OpenAI)
AZURE_AI_SERVICES_ENDPOINT=

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=

# Azure AI Search
AZURE_SEARCH_ENDPOINT=

# Azure Key Vault
AZURE_KEY_VAULT_URL=

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Entra ID / Auth (for OBO flow)
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
ENTRA_APP_CLIENT_ID=

# SharePoint
SHAREPOINT_SITE_URL=
